<Window x:Class="Motive.App.DrawerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Motive Drawer"
        Width="420"
        Height="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Slide-in from right Storyboard -->
        <Storyboard x:Key="ShowStoryboard">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BorderTransform"
                             Storyboard.TargetProperty="X"
                             From="380" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Slide-out to right Storyboard -->
        <Storyboard x:Key="HideStoryboard" Completed="HideStoryboard_Completed">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BorderTransform"
                             Storyboard.TargetProperty="X"
                             From="0" To="380" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- Left margin area leaves room for drop shadow -->
        <Border x:Name="MainBorder"
                Margin="20,0,0,0"
                Background="#1F1F1FD9"
                BorderBrush="#3D3D3D"
                BorderThickness="1,0,0,0"
                CornerRadius="16,0,0,16"
                Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="BorderTransform" X="380"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  Direction="180"
                                  ShadowDepth="3"
                                  BlurRadius="20"
                                  Opacity="0.4"/>
            </Border.Effect>

            <Grid Margin="15,15,15,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header -->
                    <RowDefinition Height="*"/>      <!-- Tabs Content -->
                    <RowDefinition Height="Auto"/>   <!-- Bottom Input -->
                </Grid.RowDefinitions>

                <!-- Header Grid -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Motive Sidebar" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Mock Agent Session Active" FontSize="11" Foreground="#8A8A8A"/>
                    </StackPanel>

                    <!-- Close Button -->
                    <ui:Button Grid.Column="1"
                               Content="&#xEA39;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Padding="8,6"
                               Click="CloseButton_Click"
                               Background="Transparent"
                               BorderThickness="0"/>
                </Grid>

                <!-- Tabs navigation and content using Wpf.Ui Navigation -->
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,10,0,10">
                    
                    <!-- Tab 1: Current Chat Log -->
                    <TabItem Header="Chat Transcript">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <StackPanel x:Name="MockMessagesPanel">
                                <!-- User Message Bubble -->
                                <Border Background="#6366F1" CornerRadius="12,12,0,12" HorizontalAlignment="Right" MaxWidth="280" Margin="0,5,0,5" Padding="12,10">
                                    <TextBlock Text="Review the project and fix the git warning" TextWrapping="Wrap" Foreground="White" FontSize="13"/>
                                </Border>

                                <!-- Agent Thoughts Bubble -->
                                <Border Background="#2B2B2B" CornerRadius="12,12,12,0" HorizontalAlignment="Left" MaxWidth="280" Margin="0,5,0,5" Padding="12,10" BorderBrush="#3D3D3D" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Agent Thoughts:" FontSize="10" FontWeight="Bold" Foreground="#F59E0B" Margin="0,0,0,4"/>
                                        <TextBlock Text="I am analyzing BinaryManager.cs to see why it references .cmd files, and checking if there are platform-specific files we can bypass." TextWrapping="Wrap" Foreground="#D1D5DB" FontSize="13"/>
                                    </StackPanel>
                                </Border>

                                <!-- Agent Action Log Box -->
                                <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,5" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#10B981" Margin="0,0,10,0" Grid.Column="0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="File Modified" FontSize="11" FontWeight="Bold" Foreground="#10B981"/>
                                            <TextBlock Text="Motive.Core/BinaryManager.cs (+40 lines)" FontSize="11" Foreground="#8A8A8A"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Agent Message Bubble -->
                                <Border Background="#2B2B2B" CornerRadius="12,12,12,0" HorizontalAlignment="Left" MaxWidth="280" Margin="0,5,0,5" Padding="12,10" BorderBrush="#3D3D3D" BorderThickness="1">
                                    <TextBlock Text="I have updated BinaryManager.cs to resolve global npm shims directly into native .exe paths. Let's run a test build." TextWrapping="Wrap" Foreground="#D1D5DB" FontSize="13"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Tab 2: Past Sessions List -->
                    <TabItem Header="History">
                        <ListView x:Name="MockSessionsList" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                            <!-- Style ListBoxItem for Fluent appearance -->
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="8,10" Width="330">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Intent}" FontWeight="SemiBold" Foreground="White" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DateStr}" Foreground="#8A8A8A" FontSize="11"/>
                                            </StackPanel>
                                            <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="16" Foreground="{Binding IconColor}" Grid.Column="1" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </TabItem>
                </TabControl>

                <!-- Bottom Input Box -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ui:TextBox x:Name="InputTextBox"
                                Grid.Column="0"
                                PlaceholderText="Reply to agent..."
                                Height="36"
                                VerticalContentAlignment="Center"
                                ClearButtonEnabled="False"
                                KeyDown="InputTextBox_KeyDown"/>

                    <ui:Button Grid.Column="1"
                               Content="&#xE724;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Height="36"
                               Width="36"
                               Margin="8,0,0,0"
                               Click="SendButton_Click"
                               Background="#6366F1"
                               Foreground="White"
                               BorderThickness="0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
