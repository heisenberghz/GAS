<ui:FluentWindow x:Class="GAS.App.ApprovalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GAS - Permission Request"
        Width="500"
        Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="15,0,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- TitleBar space -->
            <RowDefinition Height="*"/>      <!-- Permission request details -->
            <RowDefinition Height="Auto"/>   <!-- Action Buttons -->
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <ui:TitleBar Title="Permission Request" Grid.Row="0" Icon="ShieldAlert24" ShowMaximize="False" ShowMinimize="False" ShowHelp="False"/>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" Margin="10,15,10,10">
            <!-- Header -->
            <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,5">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F59E0B" Offset="0.0"/>
                        <GradientStop Color="#EF4444" Offset="1.0"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                Confirm Agent Action
            </TextBlock>

            <TextBlock Text="The AI agent requires authorization before proceeding:" FontSize="13" Foreground="#D1D5DB" Margin="0,0,0,12"/>

            <!-- Permission Scope/Type Info Card -->
            <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#333333" BorderThickness="1" Padding="12" Margin="0,0,0,15">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Action Type:" FontWeight="SemiBold" Foreground="#8A8A8A" FontSize="11" Width="80" Grid.Column="0"/>
                        <TextBlock x:Name="PermissionTypeBlock" Text="Terminal Command" FontWeight="Bold" Foreground="White" FontSize="12" Grid.Column="1"/>
                    </Grid>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Target / Detail:" FontWeight="SemiBold" Foreground="#8A8A8A" FontSize="11" Width="80" Grid.Column="0" VerticalAlignment="Top"/>
                        <TextBlock x:Name="PermissionDetailBlock" Text="git push origin main" Foreground="#E0E0E0" FontSize="12" TextWrapping="Wrap" MaxHeight="100" Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="Always Allow will create a rule in settings to skip prompting for this pattern in the future." 
                       FontSize="10" Foreground="#8A8A8A" TextWrapping="Wrap" LineHeight="14"/>
        </StackPanel>

        <!-- Footer Action Buttons -->
        <Border Grid.Row="2" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:Button x:Name="RejectButton" 
                           Grid.Column="1" 
                           Content="Deny" 
                           Appearance="Secondary"
                           Width="90" 
                           Height="32" 
                           Click="RejectButton_Click"/>

                <ui:Button x:Name="ApproveOnceButton" 
                           Grid.Column="2" 
                           Content="Allow Once" 
                           Appearance="Primary" 
                           Width="110" 
                           Height="32" 
                           Margin="8,0,0,0" 
                           Click="ApproveOnceButton_Click"/>

                <ui:Button x:Name="AlwaysAllowButton" 
                           Grid.Column="3" 
                           Content="Always Allow" 
                           Appearance="Primary" 
                           Width="110" 
                           Height="32" 
                           Margin="8,0,0,0" 
                           Click="AlwaysAllowButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
