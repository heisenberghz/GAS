<ui:FluentWindow x:Class="GAS.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings"
        Width="520"
        Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- TitleBar space -->
            <RowDefinition Height="*"/>      <!-- Settings Content -->
            <RowDefinition Height="Auto"/>   <!-- Footer Save/Cancel -->
        </Grid.RowDefinitions>

        <!-- Custom TitleBar matching Fluent design -->
        <ui:TitleBar Title="Settings" Grid.Row="0" Icon="Settings24" ShowMaximize="False" ShowMinimize="False"/>

        <!-- Main Tabbed Settings Content -->
        <TabControl Grid.Row="1" Margin="10,10,10,10" Background="Transparent" BorderThickness="0">
            
            <TabItem Header="General" Padding="12,6">
                <StackPanel Margin="5,15,5,5">
                    <TextBlock Text="Startup Configuration" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>
                    
                    <CheckBox x:Name="StartOnBootCheckBox" 
                              Content="Start GAS automatically when Windows starts" 
                              FontSize="13"
                              Margin="0,0,0,15"/>

                    <Separator Background="#2D2D2D" Height="1" Margin="0,5,0,15"/>

                    <TextBlock Text="OpenCode Engine Location" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="GAS automatically searches your system for the OpenCode engine. If you want to use a specific custom installation, browse for it below:" 
                               FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="EnginePathTextBox" 
                                    Grid.Column="0" 
                                    PlaceholderText="Path to opencode.exe or opencode.cmd (Leave empty for Auto-find)" 
                                    Height="32" 
                                    VerticalContentAlignment="Center"/>
                        <ui:Button x:Name="BrowseButton" 
                                   Grid.Column="1" 
                                   Content="Browse..." 
                                   Height="32" 
                                   Margin="8,0,0,0" 
                                   Click="BrowseButton_Click"/>
                    </Grid>

                    <Separator Background="#2D2D2D" Height="1" Margin="0,15,0,15"/>

                    <TextBlock Text="Default Workspace Folder" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="GAS auto-detects your active VS Code or Visual Studio project. Pin a folder here to always use it instead:" 
                               FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="WorkspacePathTextBox" 
                                    Grid.Column="0" 
                                    PlaceholderText="Auto-detect (leave empty to use VS Code / Visual Studio folder)" 
                                    Height="32" 
                                    VerticalContentAlignment="Center"/>
                        <ui:Button x:Name="BrowseWorkspaceButton" 
                                   Grid.Column="1" 
                                   Content="Browse..." 
                                   Height="32" 
                                   Margin="8,0,0,0" 
                                   Click="BrowseWorkspaceButton_Click"/>
                    </Grid>
                    <Separator Background="#2D2D2D" Height="1" Margin="0,15,0,15"/>

                    <TextBlock Text="Trust Mode" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="Control how GAS handles authorization requests from the AI agent:" 
                               FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <ComboBox x:Name="TrustModeComboBox" Width="180" HorizontalAlignment="Left" Height="32">
                        <ComboBoxItem Content="Careful"/>
                        <ComboBoxItem Content="Balanced"/>
                        <ComboBoxItem Content="YOLO"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>

            <!-- Tab 2: Secured API Keys -->
            <TabItem Header="API Keys" Padding="12,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5,15,15,15">
                        <TextBlock Text="AI Engine API Credentials" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBlock Text="Keys are saved locally on your machine and encrypted using Windows DPAPI, locked securely to your Windows User Account." 
                                   FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap" Margin="0,0,0,15"/>

                        <TextBlock Text="OpenAI API Key" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,5"/>
                        <ui:PasswordBox x:Name="OpenAiPasswordBox" 
                                        PlaceholderText="sk-proj-... (Paste OpenAI key here)" 
                                        Height="32" 
                                        PasswordChar="*"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,15"/>

                        <TextBlock Text="Anthropic API Key" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,5"/>
                        <ui:PasswordBox x:Name="AnthropicPasswordBox" 
                                        PlaceholderText="sk-ant-... (Paste Anthropic key here)" 
                                        Height="32" 
                                        PasswordChar="*"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,15"/>

                        <TextBlock Text="Gemini API Key" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,5"/>
                        <ui:PasswordBox x:Name="GeminiPasswordBox" 
                                        PlaceholderText="AIzaSy... (Paste Gemini key here)" 
                                        Height="32" 
                                        PasswordChar="*"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,15"/>

                        <TextBlock Text="OpenRouter API Key" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,5"/>
                        <ui:PasswordBox x:Name="OpenRouterPasswordBox" 
                                        PlaceholderText="sk-or-... (Paste OpenRouter key here)" 
                                        Height="32" 
                                        PasswordChar="*"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,15"/>

                        <TextBlock Text="Zen API Key" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,5"/>
                        <ui:PasswordBox x:Name="ZenPasswordBox" 
                                        PlaceholderText="Paste Zen key here" 
                                        Height="32" 
                                        PasswordChar="*"
                                        VerticalContentAlignment="Center"
                                        Margin="0,0,0,15"/>

                        <TextBlock Text="Ollama Endpoint" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,5"/>
                        <ui:TextBox x:Name="OllamaTextBox" 
                                    PlaceholderText="http://localhost:11434 (Optional)" 
                                    Height="32" 
                                    VerticalContentAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Hotkey Bindings -->
            <TabItem Header="Hotkey" Padding="12,6">
                <StackPanel Margin="5,15,5,5">
                    <TextBlock Text="Global Command Bar Shortcut" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="Configure the shortcut keys that trigger the floating command bar:" 
                               FontSize="11" Foreground="#8A8A8A" Margin="0,0,0,15"/>

                    <TextBlock Text="1. Select Modifiers" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,15">
                        <CheckBox x:Name="CtrlCheckBox" Content="Control (Ctrl)" IsChecked="True" Margin="0,0,15,0"/>
                        <CheckBox x:Name="ShiftCheckBox" Content="Shift" IsChecked="True" Margin="0,0,15,0"/>
                        <CheckBox x:Name="AltCheckBox" Content="Alt" IsChecked="False" Margin="0,0,15,0"/>
                    </WrapPanel>

                    <TextBlock Text="2. Select Activation Key" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                    <ComboBox x:Name="KeyComboBox" Width="150" HorizontalAlignment="Left" Height="32">
                        <ComboBoxItem Content="Space"/>
                        <ComboBoxItem Content="M"/>
                        <ComboBoxItem Content="G"/>
                        <ComboBoxItem Content="P"/>
                        <ComboBoxItem Content="S"/>
                        <ComboBoxItem Content="A"/>
                        <ComboBoxItem Content="F1"/>
                        <ComboBoxItem Content="F2"/>
                        <ComboBoxItem Content="F12"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Footer buttons Save/Cancel -->
        <Border Grid.Row="2" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0" Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:Button x:Name="SaveButton" 
                           Grid.Column="1" 
                           Content="Save Settings" 
                           Appearance="Primary" 
                           Width="120" 
                           Height="32" 
                           Click="SaveButton_Click"/>
                
                <ui:Button x:Name="CancelButton" 
                           Grid.Column="2" 
                           Content="Cancel" 
                           Width="90" 
                           Height="32" 
                           Margin="8,0,0,0" 
                           Click="CancelButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>

