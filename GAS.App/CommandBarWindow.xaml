<Window x:Class="GAS.App.CommandBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GAS Command Bar"
        Width="720"
        Height="140"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Fade-in & Slide-down Storyboard -->
        <Storyboard x:Key="ShowStoryboard">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BorderTransform"
                             Storyboard.TargetProperty="Y"
                             From="-15" To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Fade-out & Slide-up Storyboard -->
        <Storyboard x:Key="HideStoryboard" Completed="HideStoryboard_Completed">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BorderTransform"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-15" Duration="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- Main Container Border with drop shadow margin -->
        <Border x:Name="MainBorder"
                Margin="20"
                Background="#1F1F1FD9"
                BorderBrush="#3D3D3D"
                BorderThickness="1"
                CornerRadius="12"
                Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="BorderTransform" Y="-15"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  Direction="270"
                                  ShadowDepth="5"
                                  BlurRadius="25"
                                  Opacity="0.5"/>
            </Border.Effect>

            <!-- Input Bar Grid -->
            <Grid VerticalAlignment="Center" Height="50" Margin="5,0,5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search Icon -->
                <ui:SymbolIcon Symbol="Search24"
                               FontSize="20"
                               Foreground="#8A8A8A"
                               Margin="15,0,5,0"
                               VerticalAlignment="Center"
                               Grid.Column="0"/>

                <!-- Prompt Input TextBox -->
                <ui:TextBox x:Name="InputTextBox"
                            Grid.Column="1"
                            PlaceholderText="What's the plan?"
                            FontSize="18"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            VerticalContentAlignment="Center"
                            Margin="5,0,15,0"
                            Height="44"
                            ClearButtonEnabled="False"
                            GotFocus="InputTextBox_GotFocus"
                            PreviewKeyDown="InputTextBox_PreviewKeyDown"/>
            </Grid>
        </Border>
    </Grid>
</Window>

