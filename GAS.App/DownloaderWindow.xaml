<ui:FluentWindow x:Class="GAS.App.DownloaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="AI Engine Setup"
        Width="460"
        Height="240"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="15,0,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- TitleBar space -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <ui:TitleBar Title="GAS Setup" Grid.Row="0" ShowMaximize="False" ShowMinimize="False" ShowHelp="False" CanMaximize="False"/>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" Margin="10,15,10,10">
            <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,5">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#818CF8" Offset="0.0"/>
                        <GradientStop Color="#C084FC" Offset="1.0"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                Setting Up OpenCode Engine
            </TextBlock>

            <TextBlock Text="GAS is downloading the native OpenCode CLI engine to run background tasks. This will only take a moment." 
                       FontSize="12" Foreground="#D1D5DB" TextWrapping="Wrap" Margin="0,5,0,15"/>

            <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" Foreground="#818CF8" Background="#2D2D2D"/>
            
            <TextBlock x:Name="StatusTextBlock" Text="Preparing..." FontSize="11" Foreground="#8A8A8A" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0" Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ErrorTextBlock" 
                           Grid.Column="0" 
                           Text="" 
                           Foreground="#EF4444" 
                           FontSize="11" 
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ui:Button x:Name="ActionButton" 
                           Grid.Column="1" 
                           Content="Cancel" 
                           Appearance="Secondary" 
                           Width="100" 
                           Height="32" 
                           Click="ActionButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
