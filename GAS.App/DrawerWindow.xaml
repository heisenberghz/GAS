<Window x:Class="GAS.App.DrawerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="GAS Drawer"
        Width="420"
        Height="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Slide-in from right — 200ms -->
        <Storyboard x:Key="ShowStoryboard">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BorderTransform"
                             Storyboard.TargetProperty="X"
                             From="380" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Slide-out to right — 150ms -->
        <Storyboard x:Key="HideStoryboard" Completed="HideStoryboard_Completed">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BorderTransform"
                             Storyboard.TargetProperty="X"
                             From="0" To="380" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Selectable TextBox style for agent text output (looks like a label, acts like a TextBox) -->
        <Style x:Key="SelectableText" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsReadOnlyCaretVisible" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Command="ApplicationCommands.Copy" Header="Copy"/>
                        <MenuItem Command="ApplicationCommands.SelectAll" Header="Select All"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Selectable TextBox — muted variant for secondary/reasoning text -->
        <Style x:Key="SelectableTextMuted" TargetType="TextBox" BasedOn="{StaticResource SelectableText}">
            <Setter Property="Foreground" Value="#94A3B8"/>
        </Style>

        <!-- Selectable TextBox — monospace for command output -->
        <Style x:Key="SelectableTextMono" TargetType="TextBox" BasedOn="{StaticResource SelectableText}">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Left margin for drop shadow -->
        <Border x:Name="MainBorder"
                Margin="20,0,0,0"
                Background="#F00F0F12"
                BorderBrush="#2A2A34"
                BorderThickness="1,0,0,0"
                CornerRadius="16,0,0,16"
                Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="BorderTransform" X="380"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  Direction="180"
                                  ShadowDepth="2"
                                  BlurRadius="16"
                                  Opacity="0.3"/>
            </Border.Effect>

            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HistoryColumn" Width="0"/>
                    <ColumnDefinition x:Name="SplitterColumn" Width="0"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header block -->
                    <RowDefinition Height="Auto"/>   <!-- Status strip -->
                    <RowDefinition Height="*"/>      <!-- Chat transcript -->
                    <RowDefinition Height="Auto"/>   <!-- Input row -->
                </Grid.RowDefinitions>

                <!-- ═══════════════════════════════════════════ -->
                <!-- Collapsible History Sidebar                 -->
                <!-- ═══════════════════════════════════════════ -->
                <Grid x:Name="HistoryPanel" Grid.Column="0" Grid.RowSpan="4" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ui:TextBox x:Name="HistorySearchTextBox"
                                Grid.Row="0"
                                PlaceholderText="Search history..."
                                Height="32"
                                Margin="0,0,0,8"
                                VerticalContentAlignment="Center"
                                TextChanged="HistorySearchTextBox_TextChanged"/>

                    <ListView x:Name="MockSessionsList"
                              Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionChanged="SessionsList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#2A2A34" BorderThickness="0,0,0,1" Padding="8,10" Width="210">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Intent}" FontWeight="SemiBold" Foreground="#F1F5F9" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding DateStr}" Foreground="#64748B" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="13" Foreground="{Binding IconColor}" Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Splitter -->
                <Border x:Name="SidebarSplitter" Grid.Column="1" Grid.RowSpan="4" Width="1" Background="#2A2A34" Margin="8,0" Visibility="Collapsed"/>

                <!-- ═══════════════════════════════════════════ -->
                <!-- Header Block                               -->
                <!-- ═══════════════════════════════════════════ -->
                <Grid Grid.Row="0" Grid.Column="2" Margin="16,14,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Workspace info -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="WorkspaceNameText"
                                   Text="GAS"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#F1F5F9"
                                   FontFamily="Segoe UI Variable Display"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Ellipse x:Name="ConnectionDot"
                                     Width="6" Height="6"
                                     Fill="#10B981"
                                     VerticalAlignment="Center"
                                     Margin="0,0,5,0"/>
                            <TextBlock x:Name="WorkspacePathText"
                                       Text="Connected"
                                       FontSize="11"
                                       Foreground="#64748B"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="200"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- History Toggle -->
                    <ui:Button Grid.Column="1"
                               Content="&#xE81C;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Padding="8,6"
                               Margin="0,0,4,0"
                               Click="ToggleHistoryButton_Click"
                               Background="Transparent"
                               BorderThickness="0"
                               ToolTip="Toggle History"/>

                    <!-- Close Button -->
                    <ui:Button Grid.Column="2"
                               Content="&#xEA39;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Padding="8,6"
                               Click="CloseButton_Click"
                               Background="Transparent"
                               BorderThickness="0"/>
                </Grid>

                <!-- ═══════════════════════════════════════════ -->
                <!-- Status Strip                               -->
                <!-- ═══════════════════════════════════════════ -->
                <Border Grid.Row="1" Grid.Column="2"
                        Margin="14,8,14,0"
                        Background="#18181D"
                        BorderBrush="#2A2A34"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Agent state pill -->
                        <Border Grid.Column="0"
                                x:Name="AgentStatePill"
                                Background="#1E293B"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="6,2"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="AgentStateLabel"
                                       Text="● Idle"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B"/>
                        </Border>

                        <!-- Divider -->
                        <TextBlock Grid.Column="1" Text="·" FontSize="10" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <!-- Model + workspace -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusModelLabel"
                                       Text="No model"
                                       FontSize="10"
                                       Foreground="#475569"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="·" FontSize="10" Foreground="#334155" Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusWorkspaceLabel"
                                       Text="No workspace"
                                       FontSize="10"
                                       Foreground="#475569"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="100"/>
                        </StackPanel>

                        <!-- Elapsed time (hidden when idle) -->
                        <TextBlock Grid.Column="3"
                                   x:Name="ElapsedLabel"
                                   Text=""
                                   FontSize="10"
                                   Foreground="#334155"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ═══════════════════════════════════════════ -->
                <!-- Chat Transcript                            -->
                <!-- ═══════════════════════════════════════════ -->
                <ScrollViewer Grid.Row="2" Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,10,0,0"
                              Padding="14,0,14,0">
                    <StackPanel x:Name="MockMessagesPanel" Margin="0,0,0,10">
                        <!-- Bubbles are injected dynamically from DrawerWindow.xaml.cs -->
                    </StackPanel>
                </ScrollViewer>

                <!-- ═══════════════════════════════════════════ -->
                <!-- Bottom Input Row                           -->
                <!-- ═══════════════════════════════════════════ -->
                <Border Grid.Row="3" Grid.Column="2"
                        BorderBrush="#2A2A34"
                        BorderThickness="0,1,0,0"
                        Padding="14,10,14,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#18181D"
                                BorderBrush="#2A2A34"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="2">
                            <ui:TextBox x:Name="InputTextBox"
                                        PlaceholderText="Reply to agent..."
                                        Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        VerticalContentAlignment="Center"
                                        ClearButtonEnabled="False"
                                        FontSize="13"
                                        Foreground="#F1F5F9"
                                        KeyDown="InputTextBox_KeyDown"/>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#6366F1"
                                CornerRadius="10"
                                Width="38"
                                Height="38"
                                Margin="8,0,0,0"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{x:Null}"/>
                            </Border.InputBindings>
                            <ui:Button Content="&#xE724;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       Foreground="White"
                                       Click="SendButton_Click"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
