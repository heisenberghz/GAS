<ui:FluentWindow x:Class="GAS.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Welcome to GAS"
        Width="540"
        Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="15,0,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- TitleBar space -->
            <RowDefinition Height="*"/>      <!-- Welcome content & Form -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <ui:TitleBar Title="Welcome" Grid.Row="0" Icon="ArrowRight24" ShowMaximize="False" ShowMinimize="False" ShowHelp="False"/>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" Margin="10,15,10,10">
            <!-- Sleek Gradient Welcome Header -->
            <TextBlock FontSize="28" FontWeight="Bold" Margin="0,0,0,5">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#818CF8" Offset="0.0"/>
                        <GradientStop Color="#C084FC" Offset="1.0"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                Welcome to GAS
            </TextBlock>

            <TextBlock Text="Set up your AI credentials to get started" FontSize="14" Foreground="#D1D5DB" Margin="0,0,0,10"/>
            
            <TextBlock Text="GAS runs a local background agent to execute code tasks. To activate it, please enter at least one API key below. Keys are encrypted securely on your machine using Windows DPAPI." 
                       FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap" Margin="0,0,0,15" LineHeight="16"/>

            <!-- Credentials Input Forms -->
            <StackPanel>
                <!-- OpenAI -->
                <Grid Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="OpenAI API Key" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                    <ui:PasswordBox x:Name="OpenAiPasswordBox" 
                                    Grid.Row="1" 
                                    PlaceholderText="sk-proj-... (Paste OpenAI key)" 
                                    Height="32" 
                                    PasswordChar="*"
                                    VerticalContentAlignment="Center"
                                    PasswordChanged="PasswordBox_PasswordChanged"/>
                </Grid>
 
                <!-- Anthropic -->
                <Grid Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Anthropic API Key" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                    <ui:PasswordBox x:Name="AnthropicPasswordBox" 
                                    Grid.Row="1" 
                                    PlaceholderText="sk-ant-... (Paste Anthropic key)" 
                                    Height="32" 
                                    PasswordChar="*"
                                    VerticalContentAlignment="Center"
                                    PasswordChanged="PasswordBox_PasswordChanged"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0" Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status indicator warning -->
                <TextBlock x:Name="WarningTextBlock" 
                           Grid.Column="0" 
                           Text="* Paste at least one API key to proceed." 
                           Foreground="#EF4444" 
                           FontSize="11" 
                           VerticalAlignment="Center"/>

                <ui:Button x:Name="StartButton" 
                           Grid.Column="1" 
                           Content="Start GAS" 
                           Appearance="Primary" 
                           Width="120" 
                           Height="32" 
                           IsEnabled="False" 
                           Click="StartButton_Click"/>
                
                <ui:Button x:Name="QuitButton" 
                           Grid.Column="2" 
                           Content="Quit App" 
                           Width="90" 
                           Height="32" 
                           Margin="8,0,0,0" 
                           Click="QuitButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>

